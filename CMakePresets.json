{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "generator": "Ninja",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Android",
        "CMAKE_ANDROID_NDK": "$penv{ANDROID_SDK_ROOT}/ndk/27.3.13750724",
        "CMAKE_ANDROID_ARCH_ABI": "arm64-v8a",
        "EDK2_PATH": "$penv{EDK2_PATH}",
        "EDK2_ARCH": "AARCH64",
        "EDK2_TOOLCHAIN": "CLANGPDB"
      }
    },
    {
      "name": "Debug",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "EDK2_TARGET": "DEBUG"
      }
    },
    {
      "name": "Release",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "EDK2_TARGET": "RELEASE"
      }
    }
  ]
}
